@page "/Exercices/Exercice/{exerciseId:Guid}"
@model Puroguramu.App.Pages.Exercice
@{
    Layout = "_Layout"; 
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <title>@Model.ExerciseTitle</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.32.3/ace.js" crossorigin="anonymous"></script>
    <link href="~/css/SolutionPopUp.css" rel="stylesheet"/>

</head>
<body class="bg-gray-900 text-gray-200 font-sans">

<main class="min-h-screen flex flex-col items-center justify-center p-10 space-y-6">
    <!-- Exercise Section -->
    <section class="w-2/3 max-w-7xl bg-gray-800 p-6 rounded-lg shadow-lg">
        <h1 class="text-3xl font-bold text-white mb-4">@Model.ExerciseTitle</h1>
        <p class="text-lg text-gray-400 mb-4"><strong>Difficulty:</strong> @Model.ExerciseStatut</p>
        <p class="text-lg text-gray-400 mb-4"><strong>Description :</strong> @Model.DescriptionExo</p>
        <form method="post">
            <div class="space-y-6">
                <div>
                    <div id="ProposalEditor" class="ace_editor rounded-lg h-96 w-full">@Model.Proposal</div>
                    <div class="text-center mt-4">
                         @if (Model.ShowRunButton)
                                            {
                                                <button type="submit" id="runButton"
                                                        class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg">
                                                    Run
                                                </button>
                                            }
                        <button type="button" id="viewSolutionButton"
                                class="bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-lg">
                            Voir la solution
                        </button>
                    </div>
                    <input asp-for="Proposal" type="hidden">
                </div>
            </div>
        </form>
        @if (!Model.ShowRunButton)
            {
                <div id="failedMessage" class="text-center mt-4 text-red-500">
                    <p>Vous avez consulté la solution. Vous ne pouvez plus exécuter cet exercice.</p>
                </div>
            }
    </section>
    
    <div id="solutionModal" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 hidden">
        <div class="bg-gray-800 p-6 rounded-lg shadow-lg w-2/3 max-w-7xl">
            <h2 class="text-2xl font-bold text-white mb-4">Solution</h2>
            <pre id="solutionContent" class="bg-gray-900 p-2 rounded"></pre>
            <button id="closeModalButton" class="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-lg mt-4">
                Close
            </button>
        </div>
    </div>

    <!-- Test Results Section -->
    <section class="w-2/3 max-w-7xl bg-gray-800 p-6 rounded-lg shadow-lg">
        <h2 class="text-2xl font-bold text-white mb-4">Test Results</h2>
        @if (Model.TestResult.Any())
        {
        <ul class="space-y-4">
            @foreach (var testResult in Model.TestResult)
            {
            <li class="bg-gray-700 p-4 rounded-lg">
                <h3 class="text-xl font-semibold">@testResult.Label</h3>
                <p>Status: <span class="font-bold">@testResult.Status</span></p>
                @if (testResult.HasError)
                {
                <p class="text-red-500 mt-2">Error: @testResult.ErrorMessage</p>
                }
            </li>
            }
        </ul>
        }
        else
        {
        <p class="text-gray-400">No test results to display. Run the exercise to see the results.</p>
        }
        
     
    </section>

    <!-- Previous Attempts Section -->
    <section class="w-2/3 max-w-7xl bg-gray-800 p-6 rounded-lg shadow-lg">
        <h2 class="text-2xl font-bold text-white mb-4">Tentatives précedentes</h2>
        <button id="toggleAttempts"
                class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg mb-4">
            Afficher/Cacher Tentatives
        </button>
        <div id="attemptsSection" class="space-y-4">
            @if (Model.StudentExercise != null && Model.StudentExercise.Tentative != null && Model.StudentExercise.Tentative.Any())
            {
            <ul class="space-y-4">
                @foreach (var attempt in Model.StudentExercise.Tentative)
                {
                <li class="bg-gray-700 p-4 rounded-lg">
                    <p>Tentative faite le : <span class="font-bold">@attempt.AttemptedOn</span></p>
                    <p>Status: <span class="font-bold">@attempt.Status</span></p>
                    <p>Code:</p>
                    <pre class="bg-gray-900 p-2 rounded">@attempt.Code</pre>
                </li>
                }
            </ul>
            }
            else
            {
            <p class="text-gray-400">Aucune tentative effectuée.</p>
            }
        </div>
    </section>
   
</main>

<script>
    document.addEventListener('DOMContentLoaded', (evt) => {
        const proposalEditor = ace.edit("ProposalEditor");
        const proposalInput = document.getElementById("Proposal");
        proposalEditor.setTheme("ace/theme/xcode");
        proposalEditor.session.setMode("ace/mode/csharp");
        proposalInput.value = proposalEditor.session.getValue();
        proposalEditor.session.on('change', (evt) => {
            proposalInput.value = proposalEditor.session.getValue();
        });

        const toggleButton = document.getElementById("toggleAttempts");
        const attemptsSection = document.getElementById("attemptsSection");

        toggleButton.addEventListener("click", () => {
            if (attemptsSection.style.display === "none") {
                attemptsSection.style.display = "block";
            } else {
                attemptsSection.style.display = "none";
            }
        });

        attemptsSection.style.display = "none";
        
        
     const viewSolutionButton = document.getElementById("viewSolutionButton");
             const solutionModal = document.getElementById("solutionModal");
             const closeModalButton = document.getElementById("closeModalButton");
     
             viewSolutionButton.addEventListener("click", async () => {
                 const exerciseId = '@Model.IdExo';
                 const response = await fetch(`/Exercices/Exercice/${exerciseId}?handler=ViewSolution`);
                 const data = await response.text();
                 document.getElementById("solutionContent").textContent = data;
                 solutionModal.style.display = "flex";
             });
     
             closeModalButton.addEventListener("click", () => {
                 solutionModal.style.display = "none";
                 // Rediriger vers la même page pour rafraîchir
                 window.location.reload();
             });
    });
</script>
</body>
</html>