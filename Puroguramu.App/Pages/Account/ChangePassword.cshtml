@page
@model Puroguramu.App.Pages.Account.ChangePasswordModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Changer le Mot de Passe</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
      <script src="~/js/dropdown.js"></script>
</head>
<body class="bg-gray-900 text-gray-200 flex flex-col justify-between min-h-screen">

    <!-- Navigation Bar -->
 <nav class="bg-gray-800 text-gray-200 px-4 sm:px-6 py-4 shadow">
          <div class="container mx-auto flex justify-between items-center">
              <a href="/Dashboard/studentDashboard" class="flex items-center space-x-2">
                  <img src="/ressources/logo.png" alt="Logo" class="h-10 w-10">
                  <span class="font-bold text-lg">Puroguramu</span>
              </a>
              <div class="hidden md:flex items-center space-x-4">
                  <div class="relative">
                      <button id="profileButton" class="flex items-center space-x-2 focus:outline-none">
                          <img src="@(Model.Student.ProfilePicture != null ? $"data:image;base64,{Convert.ToBase64String(Model.Student.ProfilePicture)}" : "/ressources/basic.jpg")" alt="Profile Picture" class="h-12 w-12 rounded-full border-4 border-blue-500 cursor-pointer">
                          <span class="ml-2">@Model.Student.FirstName @Model.Student.LastName</span>
                      </button>
                      <div id="dropdown" class="hidden absolute right-0 mt-2 w-48 bg-gray-800 text-gray-200 rounded-md shadow-xl z-20">
                          <a href="/Account/Profile" class="block px-4 py-2 text-gray-200 hover:bg-gray-700">Modifier le Profil</a>
                      </div>
                  </div>
                  <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                      <button id="logout" type="submit" class="px-5 py-2 bg-red-600 hover:bg-red-700 rounded-md shadow-lg font-medium text-white">Déconnexion</button>
                  </form>
              </div>
          </div>
      </nav>

    <!-- Main Content Area (Form Section) -->
    <div class="flex-grow flex items-center justify-center p-4">
        <div class="w-full max-w-lg p-5 bg-gray-800 rounded-xl shadow-xl">
            <form method="POST">
                <h2 class="text-2xl font-semibold text-center mb-4">Changer le Mot de Passe</h2>

                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="bg-green-500 text-white p-4 rounded mb-4">
                        @Model.StatusMessage
                    </div>
                }

                <div class="mb-4">
                    <label asp-for="Input.CurrentPassword" class="block text-sm font-medium text-gray-400"></label>
                    <input asp-for="Input.CurrentPassword" class="mt-1 block w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Entrez votre mot de passe actuel">
                    <span asp-validation-for="Input.CurrentPassword" class="text-red-500"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Input.NewPassword" class="block text-sm font-medium text-gray-400"></label>
                    <input asp-for="Input.NewPassword" class="mt-1 block w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Entrez le nouveau mot de passe">
                    <span asp-validation-for="Input.NewPassword" class="text-red-500"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-400"></label>
                    <input asp-for="Input.ConfirmPassword" class="mt-1 block w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Confirmez le nouveau mot de passe">
                    <span asp-validation-for="Input.ConfirmPassword" class="text-red-500"></span>
                </div>

                <!-- Submit Button -->
                <div class="flex items-center justify-center">
                    <button type="submit" class="px-6 py-3 bg-blue-600 hover:bg-blue-700 rounded-md shadow-lg font-medium text-white">Changer le mot de passe</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-400 px-6 py-4 shadow w-full mt-auto">
        <div class="container mx-auto flex flex-wrap justify-between items-center">
            <a href="/Index" class="flex items-center space-x-2">
                <img src="/ressources/logo.png" alt="Logo" class="h-8">
                <span class="text-lg font-semibold">Puroguramu</span>
            </a>
            <div class="flex items-center space-x-6 text-sm">
                <a href="#" class="hover:text-white">About</a>
                <a href="#" class="hover:text-white">Privacy Policy</a>
                <a href="#" class="hover:text-white">Contact</a>
            </div>
        </div>
        <div class="text-center text-xs text-gray-400 mt-2">
            © 2023 Puroguramu™. All Rights Reserved.
        </div>
    </footer>

</body>
</html>
