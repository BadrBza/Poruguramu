@page
@model Puroguramu.App.Pages.Lecons.CreateLessonModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Créer une Leçon</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-gray-900 text-gray-200 flex flex-col min-h-screen">

    <!-- Navigation Bar -->
    <nav class="bg-gray-800 text-gray-200 px-4 sm:px-6 py-4 shadow">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/Index" class="flex items-center space-x-2">
                <img src="/ressources/logo.png" alt="Logo" class="h-10 w-10">
                <span class="font-bold text-lg">Puroguramu</span>
            </a>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="flex-grow container mx-auto p-10 mt-40"> <!-- Increased the margin-top here (mt-12) for more space -->
        <div class="max-w-md mx-auto bg-gray-800 p-8 rounded-xl shadow-lg">
            <h1 class="text-2xl font-bold text-center mb-6">Créer une Leçon</h1>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="bg-red-500 text-white p-4 rounded mb-4">
                    @Model.ErrorMessage
                </div>
            }
            <form method="post" class="space-y-6">
                <div>
                    <label for="title" class="block text-sm font-medium text-gray-300">Intitulé de la leçon</label>
                    <input type="text" id="title" name="Lesson.Title" required
                           minlength="5"
                           class="mt-1 block w-full px-3 py-2 bg-gray-700 text-gray-300 border border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                           placeholder="Entrez un intitulé d'au moins 5 caractères">
                    <span asp-validation-for="Lesson.Title" class="text-red-500"></span>
                </div>
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
                    Créer la Leçon
                </button>
            </form>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-400 px-6 py-4 shadow w-full mt-auto">
        <div class="container mx-auto flex flex-wrap justify-between items-center">
            <a href="Index" class="flex items-center space-x-2">
                <img src="/ressources/logo.png" alt="Logo" class="h-8">
                <span class="text-lg font-semibold">Puroguramu</span>
            </a>
            <div class="flex items-center space-x-6 text-sm">
                <a href="#" class="hover:text-white">About</a>
                <a href="#" class="hover:text-white">Privacy Policy</a>
                <a href="#" class="hover:text-white">Contact</a>
            </div>
        </div>
        <div class="text-center text-xs text-gray-400 mt-2">
            © 2023 Puroguramu™. All Rights Reserved.
        </div>
    </footer>

</body>
</html>
