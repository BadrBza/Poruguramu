@page
@model Puroguramu.App.Pages.IndexModel

@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Puroguramu.App
@using Puroguramu.App.Pages
<!DOCTYPE html>
<html lang="fr">
<head>
    <title>Puroguramu - Maîtrise du C#</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.32.3/ace.js"
            integrity="sha512-hWCQiPFpU0dM1jkN2dkt/OrdSXO4KN5y2utMvF0ZkacWmRvbOlEygqBW0YiJwq/nn6iywh4XnMGMG6ESQYM7WA=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
</head>
<body class="bg-gradient-to-br from-gray-900 to-gray-800 min-h-screen flex flex-col">

<!-- Navigation Bar -->
<nav class="bg-gray-800 text-gray-200 px-4 sm:px-6 py-4 shadow">
    <div class="container mx-auto flex justify-between items-center">
        <!-- Logo and branding -->
        <div class="flex items-center space-x-2">
            <a href="/Index" class="flex items-center space-x-2">
                <img src="/ressources/logo.png" alt="Logo" class="h-10 w-10">
                <span class="font-bold text-lg">Puroguramu</span>
            </a>
        </div>
        <!-- Navigation Links -->
        <div class="hidden md:flex items-center space-x-4">
            <a asp-area="Identity" asp-page="/Account/Register"
               class="bg-blue-600 hover:bg-blue-700 text-white rounded-lg px-3 py-2 transition-colors duration-200">Inscription</a>
            <a asp-area="Identity" asp-page="/Account/Login"
               class="bg-blue-600 hover:bg-blue-700 text-white rounded-lg px-3 py-2 transition-colors duration-200">Connexion</a>
        </div>
    </div>
</nav>
<!-- Main Content Area -->
<div class="flex-grow container mx-auto flex flex-col items-center justify-center py-16 px-4 sm:px-6 lg:px-8">
    <div class="flex-grow container mx-auto flex flex-col items-center justify-center py-16 px-4 sm:px-6 lg:px-8">
        <div
            class="bg-gradient-to-r from-gray-700 via-gray-800 to-gray-900 shadow-2xl rounded-3xl p-10 sm:p-12 md:p-16 lg:p-20 w-full max-w-4xl text-center transform transition duration-500 hover:scale-105">
            <h2 class="text-5xl sm:text-6xl md:text-7xl font-extrabold text-white mb-10">Bienvenue sur Puroguramu</h2>
            <p class="text-lg sm:text-2xl md:text-3xl text-gray-200 mb-12">
                Découvrez le monde du C# avec des leçons interactives, des exercices pratiques, et un soutien
                communautaire enrichissant.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
                <div
                    class="flex flex-col items-center bg-gradient-to-br from-blue-500 to-blue-700 hover:from-blue-600 hover:to-blue-800 text-white rounded-2xl p-8 shadow-2xl transform transition duration-300 hover:scale-105">
                    <h3 class="text-xl font-semibold">Leçons disponibles</h3>
                    <p class="text-4xl font-bold">@Model.LessonsCount</p>
                </div>
                <div
                    class="flex flex-col items-center bg-gradient-to-br from-blue-500 to-blue-700 hover:from-blue-600 hover:to-blue-800 text-white rounded-2xl p-8 shadow-2xl transform transition duration-300 hover:scale-105">
                    <h3 class="text-xl font-semibold">Étudiants inscrits</h3>
                    <p class="text-4xl font-bold">@Model.StudentsCount</p>
                </div>
                <div
                    class="flex flex-col items-center bg-gradient-to-br from-blue-500 to-blue-700 hover:from-blue-600 hover:to-blue-800 text-white rounded-2xl p-8 shadow-2xl transform transition duration-300 hover:scale-105">
                    <h3 class="text-xl font-semibold">Exercices disponibles</h3>
                    <p class="text-4xl font-bold">@Model.ExercicesCount</p>
                </div>
            </div>
        </div>
    </div>

</div>


<!-- Footer -->
<footer class="bg-gray-800 text-gray-400 px-6 py-4 shadow w-full mt-auto">
    <div class="container mx-auto flex flex-wrap justify-between items-center">
        <a href="/Index" class="flex items-center space-x-2">
            <img src="/ressources/logo.png" alt="Logo" class="h-8">
            <span class="text-lg font-semibold">Puroguramu</span>
        </a>
        <div class="flex items-center space-x-6 text-sm">
            <a href="#" class="hover:text-white">About</a>
            <a href="#" class="hover:text-white">Privacy Policy</a>
            <a href="#" class="hover:text-white">Contact</a>
        </div>
    </div>
    <div class="text-center text-xs text-gray-400 mt-2">
        © 2023 Puroguramu™. All Rights Reserved.
    </div>
</footer>

<script defer>
    document.addEventListener('DOMContentLoaded', (evt) => {
        const proposalEditor = ace.edit("ProposalEditor");
        const proposalInput = document.getElementById("Proposal");

        proposalEditor.setTheme("ace/theme/xcode");
        proposalEditor.session.setMode("ace/mode/csharp");

        proposalInput.value = proposalEditor.session.getValue();
        proposalEditor.session.on('change', (evt) => {
            proposalInput.value = proposalEditor.session.getValue();
        });
    });
</script>
</body>
</html>