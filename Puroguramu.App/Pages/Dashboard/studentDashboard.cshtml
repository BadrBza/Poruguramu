@page
@using Puroguramu.Infrastructures.Services
@model Puroguramu.App.Pages.Dashboard.studentDashboard

@{
    Layout = "_Layout"; 
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier le Profil</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <script src="~/js/dropdown.js"></script>
    <style>
        .nav-link {
            position: relative;
            display: inline-block;
            padding-bottom: 4px;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            width: 100%;
            transform: scaleX(0);
            height: 2px;
            bottom: 0;
            left: 0;
            background-color: #FFFFFF; 
            transform-origin: bottom right;
            transition: transform 0.25s ease-out;
        }

        .nav-link:hover::after {
            transform: scaleX(1);
            transform-origin: bottom left;
        }
    </style>
</head>
<body class="bg-gray-900 text-gray-200 flex flex-col justify-between min-h-screen">


<div class="flex-grow container mx-auto p-10">
    <h1 class="text-2xl font-bold mb-6">Tableau de Bord de l'Étudiant</h1>

    <!-- Liste des leçons publiées -->
    <div class="space-y-4">
        @foreach (var lesson in Model.PublishedLessons)
        {
        <div class="bg-gray-800 rounded-xl p-6 shadow-lg">
            <h2 class="text-xl font-semibold">
                <a href="/Lecons/LessonDetail?id=@lesson.Id" class="p-0 text-white nav-link hover:text-white">
                    @lesson.Title
                </a>
            </h2>
            <p class="text-gray-400">Progression : @lesson.CompletedExercises/@lesson.TotalExercises exercices
                réalisés</p>

            <!-- Lien vers le prochain exercice de cette leçon -->
            @if (Model.NextExercisesByLesson.TryGetValue(lesson.Id, out var nextExercise))
            {
            @if (nextExercise.ExerciseId != Guid.Empty)
            {
            <a href="/Exercices/Exercice?id=@nextExercise.ExerciseId" class="text-blue-500 hover:underline">Commencer
                le prochain exercice : @nextExercise.Title</a>
            }
            else
            {
            <p class="text-green-500">@nextExercise.Title</p>
            }
            }
        </div>
        }
    </div>
</div>

</body>
</html>