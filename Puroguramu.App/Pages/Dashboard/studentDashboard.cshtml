@page
@using Puroguramu.Infrastructures.Services
@model Puroguramu.App.Pages.Dashboard.studentDashboard

@{
Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier le Profil</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <script src="~/js/dropdown.js"></script>
</head>
<body class="bg-gray-900 text-gray-200 flex flex-col justify-between min-h-screen">

<!-- Navigation Bar -->
<nav class="bg-gray-800 text-gray-200 px-4 sm:px-6 py-4 shadow">
    <div class="container mx-auto flex justify-between items-center">
        <a href="/Dashboard/studentDashboard" class="flex items-center space-x-2">
            <img src="/ressources/logo.png" alt="Logo" class="h-10 w-10">
            <span class="font-bold text-lg">Puroguramu</span>
        </a>
        <div class="hidden md:flex items-center space-x-4">
            <div class="relative">
                <button id="profileButton" class="flex items-center space-x-2 focus:outline-none">
                    <img
                        src="@(Model.Student.ProfilePicture != null ? $"data:image;base64,{Convert.ToBase64String(Model.Student.ProfilePicture)}" : "/ressources/basic.jpg")"
                        alt="Profile Picture" class="h-12 w-12 rounded-full border-4 border-blue-500 cursor-pointer">
                    <span class="ml-2">@Model.Student.FirstName @Model.Student.LastName</span>
                </button>
                <div id="dropdown"
                     class="hidden absolute right-0 mt-2 w-48 bg-gray-800 text-gray-200 rounded-md shadow-xl z-20">
                    <a href="/Account/Profile" class="block px-4 py-2 text-gray-200 hover:bg-gray-700">Modifier le
                        Profil</a>
                    <a href="/Account/ChangePassword" class="block px-4 py-2 text-gray-200 hover:bg-gray-700">Changer le
                        Mot de Passe</a>
                </div>
            </div>
            <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                <button id="logout" type="submit"
                        class="px-5 py-2 bg-red-600 hover:bg-red-700 rounded-md shadow-lg font-medium text-white">
                    Déconnexion
                </button>
            </form>
        </div>
    </div>
</nav>


<div class="flex-grow container mx-auto p-10">
    <h1 class="text-2xl font-bold mb-6">Tableau de Bord de l'Étudiant</h1>

    <!-- Liste des leçons publiées -->
    <div class="space-y-4">
        @foreach (var lesson in Model.PublishedLessons)
        {
        <div class="bg-gray-800 rounded-xl p-6 shadow-lg">
            <h2 class="text-xl font-semibold">
                <a href="/Lecons/LessonDetail?id=@lesson.Id" class="text-blue-500 hover:underline">
                    @lesson.Title
                </a>
            </h2>
            <p class="text-gray-400">Progression : @lesson.CompletedExercises/@lesson.TotalExercises exercices
                réalisés</p>

            <!-- Lien vers le prochain exercice de cette leçon -->
            @if (Model.NextExercisesByLesson.TryGetValue(lesson.Id, out var nextExercise))
            {
            @if (nextExercise.ExerciseId != Guid.Empty)
            {
            <a href="/Exercices/DoExercise?id=@nextExercise.ExerciseId" class="text-blue-500 hover:underline">Commencer
                le prochain exercice : @nextExercise.Title</a>
            }
            else
            {
            <p class="text-green-500">@nextExercise.Title</p>
            }
            }
        </div>
        }
    </div>
</div>


<!-- Footer -->
<footer class="bg-gray-800 text-gray-400 px-6 py-4 shadow w-full mt-auto">
    <div class="container mx-auto flex flex-wrap justify-between items-center">
        <a href="Index" class="flex items-center space-x-2">
            <img src="/ressources/logo.png" alt="Logo" class="h-8">
            <span class="text-lg font-semibold">Puroguramu</span>
        </a>
        <div class="flex items-center space-x-6 text-sm">
            <a href="#" class="hover:text-white">About</a>
            <a href="#" class="hover:text-white">Privacy Policy</a>
            <a href="#" class="hover:text-white">Licensing</a>
            <a href="#" class="hover:text-white">Contact</a>
        </div>
    </div>
    <div class="text-center text-xs text-gray-400 mt-2">
        © 2023 Puroguramu™. All Rights Reserved.
    </div>
</footer>

</body>
</html>