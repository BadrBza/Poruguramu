@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion Étudiant</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-gray-900 to-gray-800 min-h-screen flex flex-col justify-between">

<div class="min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <h1 class="text-2xl font-bold mb-4 text-white text-center">Connexion</h1>
        <div class="bg-gray-900 px-8 py-8 rounded shadow-md">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div cclass="bg-green-500 text-white p-4 rounded mb-4">
                    @Model.ErrorMessage
                </div>
            }
            <form id="account" method="post" class="max-w-sm mx-auto">
                <h2 class="text-xl font-bold mb-2 text-white">Connectez-vous à votre compte</h2>
                <hr class="mb-4 border-gray-700" />
                <div asp-validation-summary="ModelOnly" class="text-red-500 bg-red-100 p-4 rounded mb-4"></div>
                <div class="mb-5">
                    <label asp-for="Input.Matricule" class="block mb-2 text-sm font-medium text-gray-300">Matricule</label>
                    <input asp-for="Input.Matricule" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" autocomplete="username" aria-required="true" />
                    <span asp-validation-for="Input.Matricule" class="text-red-500"></span>
                </div>
                <div class="mb-5">
                    <label asp-for="Input.Password" class="block mb-2 text-sm font-medium text-gray-300">Mot de passe</label>
                    <input asp-for="Input.Password" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" autocomplete="current-password" aria-required="true" />
                    <span asp-validation-for="Input.Password" class="text-red-500"></span>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">Connexion</button>
                </div>
                <div class="mt-4 text-center">
                    <p class="text-gray-400">
                        <a id="forgot-password" asp-page="./ForgotPassword" class="underline">Mot de passe oublié ?</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

</body>
</html>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
